{
  "name": "Документы",
  "table_ref": "public.rpt_documents",
  "description": "Единая модель документов (grain: 1 строка = 1 document). Фильтры по status_label или status. Отбор по типу ошибки — через модель «Разбивка ошибок» (грейн тип×документ).",
  "fields": {
    "dwh_id": { "semantic_type": "type/PK" },
    "processed_at": { "semantic_type": "type/CreationTimestamp", "display_name": "Дата обработки" },
    "processed_day": { "semantic_type": "type/CreationDate", "display_name": "День" },
    "arrival_day": { "semantic_type": "type/CreationDate", "display_name": "День поступления" },
    "clinic_jid": { "semantic_type": "type/Category", "display_name": "JID Клиники" },
    "clinic_label": { "semantic_type": "type/Title", "display_name": "Клиника" },
    "clinic_name": { "semantic_type": "type/Name", "display_name": "Наименование клиники" },
    "clinic_host": { "semantic_type": "type/URL", "display_name": "Host Клиники (ГОСТ VPN)" },
    "semd_code": { "semantic_type": "type/Category", "display_name": "Код СЭМД" },
    "semd_name": { "semantic_type": "type/Name", "display_name": "Наименование СЭМД" },
    "semd_label": { "semantic_type": "type/Title", "display_name": "СЭМД" },
    "status_label": { "semantic_type": "type/Category", "display_name": "Статус" },
    "error_types": { "semantic_type": "type/Category", "display_name": "Типы ошибки" },
    "error_summary": { "semantic_type": "type/Description", "display_name": "Сводка ошибки" },
    "error_text": { "semantic_type": "type/Description", "display_name": "Исходный текст ошибки" },
    "semd_local_uid": { "semantic_type": "type/Category", "display_name": "localUid СЭМД" },
    "relates_to_id": { "semantic_type": "type/Category", "display_name": "Связанное сообщение" },
    "semd_emdr_id": { "semantic_type": "type/Category", "display_name": "Рег. Номер РЭМД" },
    "semd_created_at": { "semantic_type": "type/CreationTimestamp", "display_name": "СЭМД CreateDate" },
    "delivery_seconds": { "semantic_type": "type/Quantity", "display_name": "Время доставки, сек" },
    "logid": { "semantic_type": "type/Category", "display_name": "LOGID" }
  },
  "hidden_fields": [
    "dwh_id",
    "status",
    "status_sort",
    "message_id",
    "processed_day",
    "arrival_day",
    "semd_code",
    "semd_name",
    "clinic_jid",
    "clinic_name",
    "clinic_inn",
    "clinic_oid",
    "error_text",
    "patient_name_masked",
    "snils_masked",
    "doctor_name",
    "patient_hash",
    "doctor_hash"
  ],
  "metrics": {
    "Документов": {
      "aggregation": ["distinct", ["field", "dwh_id", null]]
    },
    "Документов с ошибкой": {
      "aggregation": ["distinct", ["field", "dwh_id", null]],
      "filter": [
        "or",
        ["=", ["field", "status_label", null], "Ошибка связи"],
        ["=", ["field", "status_label", null], "Ошибка асинхронного ответа РЭМД"]
      ]
    }
  }
}
