{
  "name": "Документы",
  "table_ref": "public.rpt_documents",
  "description": "Единая модель документов (grain: 1 строка = 1 текущая версия логического документа, rpt_documents.is_current_version). Полный аудит всех версий — витрина rpt_document_versions. Транспорт СЭМД: request_* — отправка (getDocumentFile), result_* — исход (ответ РЭМД или сбой связи); пара MSGID запроса ↔ Связанное сообщение — ключ корреляции. Учёт: «Отправлено» (status «Отправлено») — объём отправки; статус-распределение и рейтинги (доля успеха/ошибок) считаются только на документах с вердиктом РЭМД (status ≠ «Отправлено»). Отбор по типу ошибки — через модель «Разбивка ошибок».",
  "fields": {
    "dwh_id": { "semantic_type": "type/PK" },
    "ips_date": { "semantic_type": "type/CreationTimestamp", "display_name": "Дата обработки" },
    "clinic_jid": { "semantic_type": "type/Category", "display_name": "JID Клиники" },
    "clinic_label": { "semantic_type": "type/Title", "display_name": "Клиника" },
    "clinic_name": { "semantic_type": "type/Name", "display_name": "Наименование клиники" },
    "clinic_host": { "semantic_type": "type/URL", "display_name": "Host Клиники (ГОСТ VPN)" },
    "semd_code": { "semantic_type": "type/Category", "display_name": "Код СЭМД" },
    "semd_name": { "semantic_type": "type/Name", "display_name": "Наименование СЭМД" },
    "semd_label": { "semantic_type": "type/Title", "display_name": "СЭМД" },
    "status_label": { "semantic_type": "type/Category", "display_name": "Статус" },
    "error_types": { "semantic_type": "type/Category", "display_name": "Типы ошибки" },
    "error_text": { "semantic_type": "type/Description", "display_name": "Исходный текст ошибки" },
    "semd_local_uid": { "semantic_type": "type/Category", "display_name": "localUid СЭМД" },
    "request_msgid": { "semantic_type": "type/Category", "display_name": "MSGID запроса" },
    "result_msgid": { "semantic_type": "type/Category", "display_name": "MSGID ответа" },
    "relates_to_msgid": { "semantic_type": "type/Category", "display_name": "Связанное сообщение (relatesTo)" },
    "semd_emdr_id": { "semantic_type": "type/Category", "display_name": "Рег. Номер РЭМД" },
    "semd_created_at": { "semantic_type": "type/CreationTimestamp", "display_name": "СЭМД CreateDate" },
    "delivery_seconds": { "semantic_type": "type/Quantity", "display_name": "Время доставки, сек" },
    "logid": { "semantic_type": "type/Category", "display_name": "LOGID" },
    "request_logid": { "semantic_type": "type/Category", "display_name": "LOGID запроса" },
    "result_logid": { "semantic_type": "type/Category", "display_name": "LOGID ответа" },
    "semd_version_number": { "semantic_type": "type/Quantity", "display_name": "Версия СЭМД" },
    "document_group_id": { "semantic_type": "type/Category", "display_name": "ID логического документа" }
  },
  "hidden_fields": [
    "dwh_id",
    "status",
    "status_sort",
    "semd_code",
    "semd_name",
    "clinic_jid",
    "clinic_name",
    "clinic_inn",
    "clinic_oid",
    "error_text",
    "patient_name_masked",
    "snils_masked",
    "doctor_name",
    "patient_hash",
    "doctor_hash",
    "document_group_id",
    "document_group_confidence",
    "is_current_version",
    "superseded_by_dwh_id",
    "supersedes_dwh_id"
  ],
  "metrics": {
    "Документов": {
      "aggregation": ["distinct", ["field", "dwh_id", null]]
    },
    "Документов с ошибкой": {
      "aggregation": ["distinct", ["field", "dwh_id", null]],
      "filter": [
        "or",
        ["=", ["field", "status_label", null], "Ошибка связи"],
        ["=", ["field", "status_label", null], "Ошибка асинхронного ответа РЭМД"]
      ]
    }
  }
}
