{
  "name": "Разбивка ошибок",
  "table_ref": "public.v_rpt_error_category_breakdown_ui",
  "description": "Grain: 1 строка = 1 атомарный вид ошибки на документ (occurrence). Для документов — Count distinct «Документ (ключ учёта)».",
  "fields": {
    "Обработано IPS": { "semantic_type": "type/CreationTimestamp" },
    "День (тренд)": { "semantic_type": "type/CreationDate" },
    "Документ (ключ учёта)": { "semantic_type": "type/FK" },
    "JID клиники": { "semantic_type": "type/Category" },
    "Наименование клиники": { "semantic_type": "type/Title" },
    "Код СЭМД": { "semantic_type": "type/Category" },
    "Тип СЭМД (код · НСИ)": { "semantic_type": "type/Title" },
    "Тип ошибки": { "semantic_type": "type/Category" },
    "Категория ошибки": { "semantic_type": "type/Category" }
  },
  "hidden_fields": [],
  "metrics": {
    "Вхождений ошибки": {
      "aggregation": ["count"]
    },
    "Документов с видом": {
      "aggregation": ["distinct", ["field", "Документ (ключ учёта)", null]]
    }
  }
}
