    {
      "name": "Виды ошибок по типам СЭМД",
      "description": "Вертикальный stacked-bar 100%: код СЭМД, сегменты — виды ошибки. Топ-15 кодов по объёму ошибок; в SQL — COUNT(DISTINCT документ), долю (%) Metabase считает при normalized stack.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH base AS ( SELECT COALESCE(NULLIF(TRIM(\"Код СЭМД\"), ''), 'Неизвестно') AS t, COALESCE(NULLIF(TRIM(\"Тип ошибки\"), ''), 'Неизвестная ошибка') AS k, \"Документ (ключ учёта)\" AS doc FROM public.v_rpt_error_category_breakdown_ui WHERE COALESCE(NULLIF(TRIM(\"Код СЭМД\"), ''), '') <> '' AND COALESCE(NULLIF(TRIM(\"Тип ошибки\"), ''), '') <> '' [[AND {{dwh_date}}]] [[AND {{jid}}]] [[AND {{semd_type}}]] ), totals AS ( SELECT t, COUNT(DISTINCT doc) AS total FROM base GROUP BY t ), ranked AS ( SELECT t, total, ROW_NUMBER() OVER (ORDER BY total DESC, t) AS rn FROM totals ) SELECT b.t AS \"Код СЭМД\", b.k AS \"Вид ошибки\", COUNT(DISTINCT b.doc)::bigint AS \"Документов\" FROM base b JOIN ranked r ON r.t = b.t WHERE r.rn <= 15 GROUP BY 1, 2, r.total, r.rn ORDER BY r.rn, 1, 2",
          "template-tags": {
            "jid": {
              "widget-type": "string/=",
              "display-name": "JID клиники",
              "id": "fb040801-0801-4801-8801-000000000002",
