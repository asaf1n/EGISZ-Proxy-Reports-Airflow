        "type": "native",
        "native": {
          "query": "WITH filtered AS ( SELECT * FROM public.v_rpt_documents_ui WHERE \"Статус (код)\" IN ('success', 'async_error', 'network_error') AND NULLIF(TRIM(\"Код СЭМД\"), '') IS NOT NULL AND NULLIF(TRIM(\"Тип СЭМД (код · НСИ)\"), '') IS NOT NULL [[AND {{dwh_date}}]] [[AND {{semd_type}}]] [[AND {{jid}}]] [[AND {{local_uid}}]] [[AND {{relates_to}}]] [[AND {{emdr_id}}]] [[AND {{status}}]] [[AND {{log_id}}]] ), slices AS ( SELECT f.\"Тип СЭМД (код · НСИ)\", f.\"JID клиники\"::text AS \"JID клиники\", COALESCE(NULLIF(TRIM(f.\"Наименование клиники\"), ''), '(нет)') AS \"Наименование клиники\", f.\"Документ (ключ учёта)\", f.\"Статус (код)\", COALESCE(NULLIF(TRIM(b.\"Тип ошибки\"), ''), 'Неизвестная ошибка') AS err_kind FROM filtered f INNER JOIN public.v_rpt_error_category_breakdown_ui b ON b.\"Документ (ключ учёта)\" = f.\"Документ (ключ учёта)\" ) SELECT \"Тип СЭМД (код · НСИ)\" AS \"Тип СЭМД (код · НСИ)\", \"JID клиники\", \"Наименование клиники\", err_kind AS \"Тип ошибки\", COUNT(DISTINCT \"Документ (ключ учёта)\")::bigint AS \"Документов\", COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('async_error', 'network_error'))::bigint AS \"Ошибок\", ROUND(100.0 * COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('async_error', 'network_error')) / NULLIF(COUNT(DISTINCT \"Документ (ключ учёта)\"), 0), 1) AS \"Доля ошибок\" FROM slices GROUP BY 1, 2, 3, 4 HAVING COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('async_error', 'network_error')) > 0 ORDER BY \"Ошибок\" DESC, \"Документов\" DESC LIMIT 500",
          "template-tags": {
            "jid": {
              "widget-type": "string/=",
