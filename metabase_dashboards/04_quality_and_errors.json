    {
      "display": "text",
      "text": "## Успешность по срезам\nПроблемные клиники и типы СЭМД — вверху (% успеха по возрастанию). Отказы РЭМД в колонке «Отказ РЭМД»; транспорт — дашборд **02**.",
      "sizeX": 24,
      "sizeY": 1,
      "row": 18,
      "col": 0
    },
    {
      "name": "Успешность по клиникам",
      "description": "По клиникам, COUNT DISTINCT «Документ (ключ учёта)». «Всего документов» — единый документный универсум (все 4 статуса). % успеха — по финализированным (success + ошибки), без «В обработке». Строки без JID отсекаются.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COALESCE(NULLIF(TRIM(\"JID клиники\"::text), ''), 'Неизвестно') AS \"JID клиники\", COALESCE(MAX(NULLIF(TRIM(\"Наименование клиники\"::text), '')), 'Неизвестно') AS \"Наименование клиники\", COUNT(DISTINCT \"Документ (ключ учёта)\")::bigint AS \"Всего документов\", COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\"='success')::bigint AS \"Успешно\", COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\"='async_error')::bigint AS \"Ошибок асинхронного ответа\", COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\"='waiting')::bigint AS \"В обработке\", ROUND(100.0 * COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\"='success') / NULLIF(COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('success', 'async_error', 'network_error')), 0), 1) AS \"Процент успешных (по документам)\" FROM public.v_rpt_documents_ui WHERE COALESCE(NULLIF(TRIM(\"JID клиники\"::text), ''), '') <> '' [[AND {{dwh_date}}]] [[AND {{jid}}]] [[AND {{semd_type}}]] [[AND {{status}}]] GROUP BY 1 HAVING COUNT(DISTINCT \"Документ (ключ учёта)\") > 0 ORDER BY 7 ASC NULLS LAST, 3 DESC",
          "template-tags": {
            "dwh_date": {
              "widget-type": "date/all-options",
              "display-name": "По дате «Обработано»",
              "id": "fb040401-0401-4401-8401-000000000001",
              "name": "dwh_date",
              "type": "dimension"
            },
            "jid": {
              "widget-type": "string/=",
              "display-name": "JID клиники",
              "id": "fb040401-0401-4401-8401-000000000002",
              "name": "jid",
              "type": "dimension"
            },
