    {
      "name": "Виды ошибок по типам СЭМД",
      "description": "**Горизонтальный stacked-bar:** полоса — тип СЭМД (код · НСИ), сегменты — атомарные **виды ошибки** (`v_rpt_error_category_breakdown_ui`, композитные `error_type` атомизированы по «·» между item'ами и «-» между правилами одного item), длина сегмента — **доля от общего числа ошибок, %** = COUNT(DISTINCT «Документ (ключ учёта)») сегмента к суммарному числу пар «документ × вид ошибки» во всём срезе (после фильтров). Показаны **топ-15 типов СЭМД по объёму ошибок** (хвост типов с пренебрежимо малой долей скрыт ради читаемости), по убыванию объёма; один документ с N видами учитывается N раз.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH base AS ( SELECT COALESCE(NULLIF(TRIM(\"Тип СЭМД (код · НСИ)\"), ''), 'Неизвестно') AS t, COALESCE(NULLIF(TRIM(\"Тип ошибки\"), ''), 'Неизвестная ошибка') AS k, \"Документ (ключ учёта)\" AS doc FROM public.v_rpt_error_category_breakdown_ui WHERE COALESCE(NULLIF(TRIM(\"Тип СЭМД (код · НСИ)\"), ''), '') <> '' AND COALESCE(NULLIF(TRIM(\"Тип ошибки\"), ''), '') <> '' [[AND {{dwh_date}}]] [[AND {{jid}}]] [[AND {{semd_type}}]] ), totals AS ( SELECT t, COUNT(DISTINCT doc) AS total FROM base GROUP BY t ), ranked AS ( SELECT t, total, ROW_NUMBER() OVER (ORDER BY total DESC, t) AS rn FROM totals ), grand AS ( SELECT SUM(cnt) AS total FROM ( SELECT COUNT(DISTINCT doc) AS cnt FROM base GROUP BY t, k ) s ) SELECT b.t AS \"Тип СЭМД\", b.k AS \"Вид ошибки\", ROUND(100.0 * COUNT(DISTINCT b.doc) / NULLIF((SELECT total FROM grand), 0), 1)::numeric AS \"% ошибок\" FROM base b JOIN ranked r ON r.t = b.t WHERE r.rn <= 15 GROUP BY 1, 2, r.total, r.rn ORDER BY r.rn, 1, 2",
          "template-tags": {
            "dwh_date": {
              "widget-type": "date/all-options",
              "display-name": "По дате «Обработано»",
              "id": "fb040801-0801-4801-8801-000000000001",
