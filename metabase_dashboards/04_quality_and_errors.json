    {
      "name": "% ошибок: клиника × тип СЭМД",
      "description": "Срез доли ошибок по парам **клиника × тип СЭМД (код · НСИ)**. Метрика: COUNT(DISTINCT «Документ (ключ учёта)»). «% ошибок» = документы со статусом «Ошибка асинхронного ответа РЭМД» или «Ошибка связи» к финализированным (success + ошибки) в срезе. Показаны только пары с ≥1 ошибкой; сортировка по убыванию доли ошибок, затем по объёму. «Всего» — финализированные документы в паре (контекст знаменателя: % на 1 документе шумит). Без ограничения числа строк.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COALESCE(NULLIF(TRIM(\"JID клиники\"::text), ''), 'Неизвестно') AS \"JID клиники\", COALESCE(MAX(NULLIF(TRIM(\"Наименование клиники\"::text), '')), 'Неизвестно') AS \"Клиника\", COALESCE(NULLIF(TRIM(\"Тип СЭМД (код · НСИ)\"), ''), 'Неизвестно') AS \"Тип СЭМД (код · НСИ)\", COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('success', 'async_error', 'network_error'))::bigint AS \"Всего\", COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('async_error', 'network_error'))::bigint AS \"Ошибок\", ROUND(100.0 * COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('async_error', 'network_error')) / NULLIF(COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('success', 'async_error', 'network_error')), 0), 1) AS \"% ошибок\" FROM public.v_rpt_documents_ui WHERE \"Статус (код)\" IN ('success', 'async_error', 'network_error') AND COALESCE(NULLIF(TRIM(\"JID клиники\"::text), ''), '') <> '' AND COALESCE(NULLIF(TRIM(\"Код СЭМД\"), ''), '') <> '' [[AND {{dwh_date}}]] [[AND {{jid}}]] [[AND {{semd_type}}]] GROUP BY 1, 3 HAVING COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('async_error', 'network_error')) > 0 ORDER BY 6 DESC, 5 DESC",
