      "row": 4,
      "col": 0,
      "visualization_settings": {}
    },
    {
      "name": "Тепловая карта: клиника × день",
      "description": "Тепловая карта по колбэкам: календарный день из **Обработано IPS**, клиника, доля ошибок (%). Учёт документов — COUNT(DISTINCT «Документ (ключ учёта)»), как в эталоне «Итоги по ошибкам». Фильтры дашборда: период **«Обработано IPS»**, **JID клиники**, **Тип СЭМД**; без выбранного периода даты в SQL не режутся.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH d AS ( SELECT date_trunc('day', \"Дата обработки\")::date AS day, COALESCE(NULLIF(TRIM(\"Наименование клиники\"), ''), 'JID ' || \"JID клиники\"::text) AS clinic, COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('success', 'async_error', 'network_error')) AS cnt, COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('async_error', 'network_error')) AS err FROM public.v_rpt_documents_ui WHERE NULLIF(TRIM(\"JID клиники\"::text), '') IS NOT NULL [[AND {{dwh_date}}]] [[AND {{jid}}]] [[AND {{semd_type}}]] GROUP BY 1, 2 ) SELECT day AS \"День\", clinic AS \"Клиника\", ROUND(100.0 * err / NULLIF(cnt, 0), 1) AS \"Доля ошибок, %\" FROM d ORDER BY 1, 2",
          "template-tags": {
            "jid": {
              "widget-type": "string/=",
              "display-name": "JID клиники",
              "id": "fb040301-0301-4301-8301-000000000002",
              "name": "jid",
              "type": "dimension"
            },
            "dwh_date": {
              "widget-type": "date/all-options",
