    {
      "name": "08 · Распределение пациентов по числу ЭМД",
      "description": "Histogram: сколько у клиники пациентов с 1, 2-3, 4-10, 11+ документами. Признак приверженности наблюдению.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH per_patient AS (SELECT patient_hash, COUNT(DISTINCT document_key)::int AS doc_cnt FROM public.v_rpt_client_documents_ui WHERE client_jid = {{client_jid}} AND patient_hash IS NOT NULL [[AND {{client_period}}]] [[AND {{client_document_type}}]] GROUP BY patient_hash) SELECT CASE WHEN doc_cnt = 1 THEN '1 документ' WHEN doc_cnt BETWEEN 2 AND 3 THEN '2-3' WHEN doc_cnt BETWEEN 4 AND 10 THEN '4-10' ELSE '11+' END AS \"Документов на пациента\", COUNT(*)::bigint AS \"Пациентов\" FROM per_patient GROUP BY 1 ORDER BY MIN(doc_cnt)",
