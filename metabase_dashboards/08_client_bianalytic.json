    {
      "name": "08 · Динамика по типам СЭМД (месяцы)",
      "description": "Stacked bar: объём по типам СЭМД помесячно. Показывает сезонность и сдвиги в номенклатуре документов.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH base AS (SELECT date_trunc('month', document_ts)::date AS month_, COALESCE(NULLIF(document_type, ''), '(тип СЭМД не определен)') AS document_type_, COUNT(DISTINCT document_key)::bigint AS cnt FROM public.v_rpt_client_documents_ui WHERE client_jid = {{client_jid}} AND document_ts IS NOT NULL [[AND {{client_period}}]] [[AND {{client_document_type}}]] GROUP BY 1, 2), ranked AS (SELECT document_type_, SUM(cnt) AS total_cnt, ROW_NUMBER() OVER (ORDER BY SUM(cnt) DESC) AS rn FROM base GROUP BY 1) SELECT b.month_ AS \"Месяц\", CASE WHEN r.rn <= 6 THEN b.document_type_ ELSE 'Остальные' END AS \"Тип СЭМД\", SUM(b.cnt)::bigint AS \"Документов\" FROM base b JOIN ranked r USING (document_type_) GROUP BY 1, 2 ORDER BY 1, 3 DESC",
          "template-tags": {
            "client_jid": {
              "widget-type": "string/=",
              "display-name": "JID клиники",
              "id": "08b50000-0000-4000-8000-000000000003",
              "name": "client_jid",
              "required": true,
              "type": "text"
            },
            "client_period": {
              "widget-type": "date/all-options",
              "display-name": "Период",
              "id": "08b50000-0000-4000-8000-000000000001",
              "name": "client_period",
              "type": "dimension"
            },
            "client_document_type": {
              "widget-type": "string/=",
              "display-name": "Тип документа",
              "id": "08b50000-0000-4000-8000-000000000002",
              "name": "client_document_type",
              "type": "dimension"
            }
          }
        },
        "database": 1
      },
      "display": "bar",
      "visualization_settings": {
        "stackable.stack_type": "stacked",
        "graph.dimensions": [
          "Месяц",
          "Тип СЭМД"
        ],
        "graph.metrics": [
          "Документов"
        ]
      },
      "sizeX": 12,
      "sizeY": 7,
      "row": 4,
      "col": 0,
      "metabase-field-filters": {
        "client_period": {
          "table_ref": "public.v_rpt_client_documents_ui",
          "field_name": "document_ts"
        },
        "client_document_type": {
