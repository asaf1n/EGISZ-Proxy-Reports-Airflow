    {
      "name": "Динамика документов по типам СЭМД",
      "description": "Stacked bar: объём по типам СЭМД помесячно. Показывает сезонность и сдвиги в номенклатуре документов.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH base AS (SELECT date_trunc('month', ips_date)::date AS month_, COALESCE(NULLIF(semd_label, ''), '(тип СЭМД не определен)') AS semd_label_, COUNT(DISTINCT dwh_id)::bigint AS cnt FROM public.rpt_documents WHERE clinic_jid::text = {{client_jid}} AND ips_date IS NOT NULL [[AND {{ips_date}}]] [[AND {{client_document_type}}]] GROUP BY 1, 2), ranked AS (SELECT semd_label_, SUM(cnt) AS total_cnt, ROW_NUMBER() OVER (ORDER BY SUM(cnt) DESC) AS rn FROM base GROUP BY 1) SELECT b.month_ AS \"Месяц\", CASE WHEN r.rn <= 6 THEN b.semd_label_ ELSE 'Остальные' END AS \"Тип СЭМД\", SUM(b.cnt)::bigint AS \"Документов\" FROM base b JOIN ranked r USING (semd_label_) GROUP BY 1, 2 ORDER BY 1, 3 DESC",
          "template-tags": {
            "client_jid": {
              "type": "text",
              "display-name": "JID Клиники",
              "id": "08c50000-0000-4000-8000-000000000003",
              "name": "client_jid",
              "required": true,
              "widget-type": "string/="
            },
            "client_document_type": {
              "widget-type": "string/=",
              "display-name": "Тип документа",
              "id": "08c50000-0000-4000-8000-000000000002",
              "name": "client_document_type",
              "type": "dimension"
            },
            "ips_date": {
              "widget-type": "date/all-options",
              "display-name": "Период",
              "id": "08c50000-0000-4000-8000-000000000001",
              "name": "ips_date",
              "type": "dimension"
            }
          }
        },
        "database": 1
      },
      "display": "bar",
      "visualization_settings": {
        "graph.dimensions": [
          "Месяц",
          "Тип СЭМД"
        ],
        "stackable.stack_type": "stacked",
        "column_settings": {
          "[\"name\",\"Документов\"]": {
            "decimals": 0,
            "number_separators": ", "
          }
        },
        "graph.metrics": [
          "Документов"
        ]
      },
