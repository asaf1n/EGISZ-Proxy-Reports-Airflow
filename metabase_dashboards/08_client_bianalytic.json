        "type": "native",
        "native": {
          "query": "SELECT COUNT(DISTINCT patient_hash)::bigint AS \"Пациентов\" FROM public.v_rpt_client_documents_ui WHERE client_jid = {{client_jid}} AND patient_hash IS NOT NULL [[AND {{client_period}}]] [[AND {{client_document_type}}]]",
