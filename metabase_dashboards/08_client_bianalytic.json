    {
      "name": "Среднее время доставки по типам СЭМД",
      "description": "AVG(delivery_seconds) по успешным СЭМД с разбивкой на типы. Выявляет, какие документы дольше всего идут до РЭМД.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COALESCE(NULLIF(semd_label, ''), '(тип СЭМД не определен)') AS \"Тип СЭМД\", ROUND(AVG(delivery_seconds) / 60.0, 1) AS \"Доставка, мин\", COUNT(DISTINCT dwh_id) FILTER (WHERE delivery_seconds IS NOT NULL)::bigint AS \"Документов с метрикой\" FROM public.rpt_documents WHERE clinic_jid::text = {{client_jid}} AND delivery_seconds IS NOT NULL [[AND {{ips_date}}]] [[AND {{client_document_type}}]] GROUP BY 1 HAVING COUNT(DISTINCT dwh_id) FILTER (WHERE delivery_seconds IS NOT NULL) >= 3 ORDER BY 2 DESC LIMIT 12",
