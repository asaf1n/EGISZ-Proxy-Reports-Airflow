    {
      "name": "08 · % успеха регистрации по типам СЭМД",
      "description": "Доля успешных СЭМД по типу. Низкая доля = код/шаблон СЭМД часто отклоняется РЭМД, стоит проверить структуру документа.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COALESCE(NULLIF(document_type, ''), '(тип СЭМД не определен)') AS \"Тип СЭМД\", ROUND(100.0 * COUNT(DISTINCT document_key) FILTER (WHERE status_code = 'success') / NULLIF(COUNT(DISTINCT document_key) FILTER (WHERE status_code IN ('success', 'async_error', 'network_error')), 0), 1) AS \"% успеха\", COUNT(DISTINCT document_key)::bigint AS \"Документов\" FROM public.v_rpt_client_documents_ui WHERE client_jid = {{client_jid}} [[AND {{client_period}}]] [[AND {{client_document_type}}]] GROUP BY 1 HAVING COUNT(DISTINCT document_key) > 0 ORDER BY 3 DESC LIMIT 12",
          "template-tags": {
