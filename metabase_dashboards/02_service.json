    {
      "name": "02 · Heatmap клиники × дни (доля ошибок)",
      "description": "Тепловая карта по колбэкам: календарный день из **Обработано IPS**, клиника, доля ошибок (%). Тот же учёт документов, что архив и топы на **02** (COUNT DISTINCT «Документ (ключ учёта)»). Период — общий фильтр **Период по «Обработано IPS» (колбэки)**; без выбранного периода даты в SQL не режутся (лучше задать диапазон, как на **06**).",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH d AS ( SELECT date_trunc('day', \"Дата обработки\")::date AS day, COALESCE(NULLIF(TRIM(\"Наименование клиники\"), ''), 'JID ' || \"JID клиники\"::text) AS clinic, COUNT(DISTINCT \"Документ (ключ учёта)\") AS cnt, COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус\" = 'error') AS err FROM public.v_rpt_documents_ui WHERE NULLIF(TRIM(\"JID клиники\"::text), '') IS NOT NULL [[AND {{dwh_date}}]] [[AND NULLIF(TRIM(\"Код СЭМД\"), '') = {{top_semd}}]] [[AND \"JID клиники\"::text = {{top_clinic}}]] GROUP BY 1, 2 ) SELECT day AS \"День\", clinic AS \"Клиника\", ROUND(100.0 * err / NULLIF(cnt, 0), 2) AS \"Доля ошибок, %\" FROM d ORDER BY 1, 2",
          "template-tags": {
            "top_clinic": {
              "widget-type": "string/=",
              "display-name": "JID клиники",
              "id": "h1100002-1001-4101-8101-000000000010",
              "name": "top_clinic",
              "type": "dimension"
            },
            "dwh_date": {
              "widget-type": "date/all-options",
              "display-name": "По дате «Обработано»",
              "id": "f2000007-0007-4007-8007-000000000001",
