    {
      "name": "async vs network",
      "description": "Доля ошибок связи (только при идентификаторе документа в журнале) vs асинхронный ответ РЭМД; уникальные документы (DISTINCT document_key). Период — `parse_created_filter` (created_at, healthcheck).",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT CASE WHEN COALESCE(NULLIF(error_top_type, ''), 'async_response') = 'network' THEN 'Ошибка связи' ELSE 'Ошибка в асинхронном ответе РЭМД' END AS \"Тип\", COUNT(DISTINCT document_key)::bigint AS \"Уникальных документов\" FROM public.v_stg_channel_errors_by_document WHERE NOT ( (error_top_type = 'network' OR UPPER(COALESCE(error_code::text, '')) IN ('NETWORK_ERROR', 'INTEGRATION_LOGSTATE_3')) AND NULLIF(TRIM(relates_to_id::text), '') IS NULL AND NULLIF(TRIM(relates_to_hint::text), '') IS NULL AND NULLIF(TRIM(local_uid_hint::text), '') IS NULL AND NULLIF(TRIM(emdr_id_hint::text), '') IS NULL ) [[AND {{parse_created}}]] GROUP BY 1 ORDER BY 2 DESC",
          "template-tags": {
            "parse_created": {
              "widget-type": "date/all-options",
              "display-name": "По дате created_at (healthcheck)",
              "id": "f3a00003-0003-4003-8003-000000099001",
              "name": "parse_created",
              "type": "dimension"
            }
          }
        },
        "database": 1
      },
