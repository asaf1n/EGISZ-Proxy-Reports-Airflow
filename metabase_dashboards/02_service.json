    {
      "name": "Ошибки регистрации в РЭМД ЕГИСЗ (тренд)",
      "description": "Динамика **уникальных документов** со сбоем канала (`document_key`) по часам. Ось времени — **created_at** в `stg_channel_errors` (не IPS). Используйте фильтр по **created_at**; без него берётся окно **30 суток до MAX(created_at)** (не привязано к календарю сервера).",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH b AS ( SELECT COALESCE((SELECT MAX(created_at) FROM public.v_stg_channel_errors_by_document), NOW()) AS mx ) SELECT date_trunc('hour', created_at) AS \"Час\", COUNT(DISTINCT document_key)::bigint AS \"Уникальных документов с ошибкой\" FROM public.v_stg_channel_errors_by_document CROSS JOIN b WHERE created_at >= b.mx - INTERVAL '30 days' [[AND {{parse_created}}]] GROUP BY 1 ORDER BY 1",
          "template-tags": {
            "parse_created": {
              "widget-type": "date/all-options",
              "display-name": "По дате created_at (healthcheck)",
              "id": "f3a00002-0002-4002-8002-000000099002",
              "name": "parse_created",
              "type": "dimension"
            }
          }
        },
        "database": 1
