  "cards": [
    {
      "name": "Сетевые ошибки (тренд)",
      "description": "Динамика транспортных ошибок по часам: **COUNT(DISTINCT …)** по ключу группировки; ось — **«Дата создания документа»** (`v_rpt_network_errors_detail_ui`).",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH b AS ( SELECT COALESCE((SELECT MAX(\"Дата создания документа\") FROM public.v_rpt_network_errors_detail_ui), NOW()) AS mx ) SELECT date_trunc('hour', \"Дата создания документа\") AS \"Час\", COUNT(DISTINCT \"Документ (ключ учёта)\")::bigint AS \"Уникальных документов\" FROM public.v_rpt_network_errors_detail_ui CROSS JOIN b WHERE \"Дата создания документа\" >= b.mx - INTERVAL '30 days' [[AND {{parse_created}}]] GROUP BY 1 ORDER BY 1",
          "template-tags": {
            "parse_created": {
              "widget-type": "date/all-options",
              "display-name": "По дате «Дата создания документа» (ошибки связи)",
              "id": "f3a00004-0004-4004-8004-000000099001",
              "name": "parse_created",
              "type": "dimension"
            }
          }
        },
        "database": 1
      },
