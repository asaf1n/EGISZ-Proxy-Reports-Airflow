    {
      "name": "Ошибки по клиникам: объём и %",
      "description": "Топ-12 клиник по объёму отказов РЭМД (async_error + network_error). Объединяет прежние «error rate» и «очаги»: столбец «Ошибок» (левая ось) — масштаб очага/объём, столбец «% ошибок» (правая ось) — доля отказов внутри клиники. Оба показателя — СТОЛБЦЫ, без линии: клиники несопоставимы как непрерывный ряд, линия ложно их связывала. Учёт СЭМД — «Документ (ключ учёта)». Период по «Обработано IPS».",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH per_clinic AS ( SELECT (LEFT(COALESCE(NULLIF(TRIM(\"Наименование клиники\"), ''), '(нет)'), 22) || ' | ' || \"JID клиники\"::text) AS lbl, COUNT(DISTINCT \"Документ (ключ учёта)\")::bigint AS total, COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('async_error','network_error'))::bigint AS errs FROM public.v_rpt_documents_ui WHERE \"Статус (код)\" IN ('success','async_error','network_error') AND NULLIF(TRIM(\"JID клиники\"::text), '') IS NOT NULL [[AND {{dwh_date}}]] [[AND {{top_semd}}]] [[AND {{top_clinic}}]] [[AND {{local_uid}}]] [[AND {{relates_to}}]] [[AND {{emdr_id}}]] [[AND {{status}}]] [[AND {{log_id}}]] GROUP BY 1 ), ranked AS ( SELECT lbl, errs, ROUND(100.0*errs/NULLIF(total,0),1) AS rate, ROW_NUMBER() OVER (ORDER BY errs DESC, total DESC) AS rn FROM per_clinic WHERE errs > 0 ) SELECT lbl AS \"Клиника\", errs AS \"Ошибок\", rate AS \"% ошибок\" FROM ranked WHERE rn <= 12 ORDER BY errs DESC",
          "template-tags": {
            "top_clinic": {
              "widget-type": "string/=",
