    {
      "name": "Ошибок по СЭМД",
      "description": "Топ-8 кодов СЭМД по объёму отказов РЭМД + «Прочие». Колонка «%» — доля ошибок среди всех документов данного типа (не доля в общем числе ошибок).",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH per_code AS ( SELECT \"Код СЭМД\" AS code, COUNT(DISTINCT \"Документ (ключ учёта)\")::bigint AS total, COUNT(DISTINCT \"Документ (ключ учёта)\") FILTER (WHERE \"Статус (код)\" IN ('async_error','network_error'))::bigint AS errs FROM public.v_rpt_documents_ui WHERE \"Статус (код)\" IN ('success','async_error','network_error') AND NULLIF(TRIM(\"Код СЭМД\"), '') IS NOT NULL [[AND {{dwh_date}}]] [[AND {{top_semd}}]] [[AND {{top_clinic}}]] [[AND {{local_uid}}]] [[AND {{relates_to}}]] [[AND {{emdr_id}}]] [[AND {{status}}]] [[AND {{log_id}}]] GROUP BY 1 ), ranked AS ( SELECT code, total, errs, ROW_NUMBER() OVER (ORDER BY errs DESC) AS rn FROM per_code WHERE errs > 0 ) SELECT CASE WHEN rn <= 8 THEN code ELSE 'Прочие' END AS \"Код СЭМД\", SUM(errs)::bigint AS \"Ошибок\", ROUND(100.0 * SUM(errs) / NULLIF(SUM(total), 0), 1) AS \"%\" FROM ranked GROUP BY 1 ORDER BY 2 DESC",
          "template-tags": {
