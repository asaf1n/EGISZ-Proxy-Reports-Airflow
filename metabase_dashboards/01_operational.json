    {
      "name": "Статусы за период",
      "description": "Единая нотификация статуса документа (4 значения): Успешно зарегистрирован / Ошибка асинхронного ответа РЭМД / Ошибка связи / В обработке. Сумма долей = общему числу документов за период (тот же универсум, что у счётчиков «всего документов»). Очередь «В обработке» детализируется на дашборде 03.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT \"Статус\", COUNT(DISTINCT \"Документ (ключ учёта)\")::bigint AS \"Документов\" FROM public.v_rpt_documents_ui WHERE 1=1 [[AND {{dwh_date}}]] [[AND NULLIF(TRIM(\"Код СЭМД\"), '') = {{top_semd}}]] [[AND \"JID клиники\"::text = {{top_clinic}}]] GROUP BY 1 HAVING COUNT(DISTINCT \"Документ (ключ учёта)\") > 0 ORDER BY 2 DESC",
