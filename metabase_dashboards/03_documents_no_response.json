    {
      "name": "Возраст зависших документов",
      "description": "Распределение по времени ожидания с порогом эскалации **72 часа** (после — «просрочено», требует разбора). «Сейчас» для расчёта — момент последней «Отправлено» в снимке.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH base AS ( SELECT * FROM public.v_rpt_documents_no_response_ui WHERE 1=1 [[AND {{dwh_date}}]] [[AND {{top_semd}}]] [[AND {{top_clinic}}]] [[AND {{local_uid}}]] AND \"Отправлено\" IS NOT NULL ), pend_ref AS ( SELECT COALESCE(MAX(\"Отправлено\"), NOW()) AS ref_ts FROM base ) SELECT CASE WHEN p.\"Отправлено\" IS NULL THEN 'дата неизвестна' WHEN EXTRACT(EPOCH FROM (pend_ref.ref_ts - p.\"Отправлено\"))/3600 < 1 THEN 'менее 1 часа' WHEN EXTRACT(EPOCH FROM (pend_ref.ref_ts - p.\"Отправлено\"))/3600 < 12 THEN '1–12 часов' WHEN EXTRACT(EPOCH FROM (pend_ref.ref_ts - p.\"Отправлено\"))/3600 < 24 THEN '12–24 часа' WHEN EXTRACT(EPOCH FROM (pend_ref.ref_ts - p.\"Отправлено\"))/3600 < 72 THEN '24–72 часа' ELSE 'просрочено (>72ч)' END AS \"Время ожидания\", COUNT(DISTINCT p.\"localUid СЭМД\")::bigint AS \"Документов\" FROM base p CROSS JOIN pend_ref GROUP BY 1 ORDER BY MIN(EXTRACT(EPOCH FROM (pend_ref.ref_ts - p.\"Отправлено\")))",
          "template-tags": {
            "top_clinic": {
              "widget-type": "string/=",
              "display-name": "JID клиники",
              "id": "f8000002-0002-4002-8002-000000000011",
              "name": "top_clinic",
              "required": false,
              "type": "dimension"
            },
            "dwh_date": {
              "widget-type": "date/all-options",
              "display-name": "По дате «Отправлено»",
              "id": "f8000002-0002-4002-8002-000000000001",
              "name": "dwh_date",
              "type": "dimension"
            },
            "local_uid": {
              "widget-type": "string/=",
              "display-name": "localUid СЭМД",
              "id": "f8000002-0002-4002-8002-000000000012",
              "name": "local_uid",
              "required": false,
              "type": "dimension"
            },
            "top_semd": {
              "widget-type": "string/=",
              "display-name": "Код СЭМД",
              "id": "f8000002-0002-4002-8002-000000000010",
              "name": "top_semd",
              "required": false,
              "type": "dimension"
            }
          }
