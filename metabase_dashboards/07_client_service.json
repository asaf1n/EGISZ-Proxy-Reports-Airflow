    {
      "name": "Успешно зарегистрирован",
      "description": "Документы с финальным статусом «Успешно зарегистрирован» + конверсия от финальных ответов.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT CONCAT(COUNT(DISTINCT document_key) FILTER (WHERE status_code = 'success')::text, ' (', COALESCE(ROUND(100.0 * COUNT(DISTINCT document_key) FILTER (WHERE status_code = 'success') / NULLIF(COUNT(DISTINCT document_key) FILTER (WHERE status_code IN ('success', 'async_error', 'network_error')), 0), 1), 0)::text, '%)') AS \"Успешно\" FROM public.v_rpt_client_documents_ui WHERE client_jid = {{client_jid}} [[AND {{client_period}}]] [[AND {{client_document_type}}]]",
