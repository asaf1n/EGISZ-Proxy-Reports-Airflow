    {
      "name": "Среднее время регистрации СЭМД",
      "description": "От создания СЭМД в МИС до получения ответа РЭМД. Конвертируется в минуты/часы для читаемости.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH base AS (SELECT AVG(delivery_seconds)::numeric AS avg_sec FROM public.v_rpt_client_documents_ui WHERE client_jid = {{client_jid}} AND delivery_seconds IS NOT NULL [[AND {{client_period}}]] [[AND {{client_document_type}}]]) SELECT CASE WHEN avg_sec IS NULL THEN 'нет данных' WHEN avg_sec < 60 THEN ROUND(avg_sec, 0)::text || ' сек' WHEN avg_sec < 3600 THEN ROUND(avg_sec / 60.0, 1)::text || ' мин' WHEN avg_sec < 86400 THEN ROUND(avg_sec / 3600.0, 1)::text || ' ч' ELSE ROUND(avg_sec / 86400.0, 1)::text || ' сут' END AS \"Среднее время доставки\" FROM base",
          "template-tags": {
            "client_jid": {
              "type": "text",
              "display-name": "JID клиники",
              "id": "07c70000-0000-4000-8000-000000000003",
              "name": "client_jid",
              "required": true,
              "widget-type": "string/="
            },
            "client_document_type": {
