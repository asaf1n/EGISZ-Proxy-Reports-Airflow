    {
      "name": "07 · Успешно зарегистрировано в РЭМД",
      "description": "Документы со статусом success + конверсия от общего числа.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT CONCAT(COUNT(DISTINCT document_key) FILTER (WHERE status_code = 'success')::text, ' (', COALESCE(ROUND(100.0 * COUNT(DISTINCT document_key) FILTER (WHERE status_code = 'success') / NULLIF(COUNT(DISTINCT document_key) FILTER (WHERE status_code <> 'pending'), 0), 1), 0)::text, '%)') AS \"Успешно\" FROM public.v_rpt_client_documents_ui WHERE client_jid = {{client_jid_stub}} [[AND {{client_period}}]] [[AND {{client_document_type}}]]",
          "template-tags": {
            "client_jid_stub": {
