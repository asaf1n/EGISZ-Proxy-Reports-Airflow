              "display-name": "Тип документа",
              "id": "07c70000-0000-4000-8000-000000000002",
              "name": "client_document_type",
              "type": "dimension"
            },
            "client_period": {
              "widget-type": "date/all-options",
              "display-name": "Период",
              "id": "07c70000-0000-4000-8000-000000000001",
              "name": "client_period",
              "type": "dimension"
            }
          }
        },
        "database": 1
