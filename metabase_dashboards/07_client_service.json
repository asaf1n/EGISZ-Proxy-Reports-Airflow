  "cards": [
    {
      "display": "text",
      "text": "## Мониторинг интеграции с ЕГИСЗ\nОбщие объёмы и статусы регистрации СЭМД по вашей клинике. Личные данные пациентов маскированы.",
      "sizeX": 24,
      "sizeY": 1,
      "row": 0,
      "col": 0
    },
    {
      "name": "07 · Всего отправлено документов",
      "description": "Количество уникальных СЭМД (по document_key) за выбранный период.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COUNT(DISTINCT document_key)::bigint AS \"Документов\" FROM public.v_rpt_client_documents_ui WHERE client_jid = {{client_jid_stub}} [[AND {{client_period}}]] [[AND {{client_document_type}}]]",
          "template-tags": {
            "client_jid_stub": {
              "widget-type": "string/=",
              "display-name": "JID (заглушка авторизации)",
              "id": "07c10000-0000-4000-8000-000000000003",
              "name": "client_jid_stub",
              "required": true,
              "type": "text"
            },
            "client_period": {
              "widget-type": "date/all-options",
              "display-name": "Период",
